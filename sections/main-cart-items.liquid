{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Hide default title/header block entirely (was: hiding children only,
     which left the parent's margin/padding as a stray gap at the top) */
  .title-wrapper-with-link {
    display: none !important;
  }
  .cart-items thead { display: none !important; }
  .loading-overlay, .loading-overlay__spinner { display: none !important; }

  /* ALL CAPS global */
  .cart__contents, .cart-item__name, .cart-item__name a,
  .cart-item__details, .totals__total, .totals__total-value,
  .cart__checkout-button, .cart__ctas,
  .cart-item__discounted-prices, .discounts__discount, .cart__tax-note {
    text-transform: uppercase !important;
    letter-spacing: 1px;
  }

  /* PRODUCT NAME */
  .cart-item__name,
  .cart-item__name a {
    font-size: 22px !important;
    font-weight: 600 !important;
    letter-spacing: 1.2px !important;
    text-transform: uppercase !important;
    font-style: normal !important;
    color: #000 !important;
    font-family: 'Inter', sans-serif !important;
  }

  /* PRICE */
  .cart-items .price,
  .cart-items .price--end,
  .cart-items .price.price--end,
  .cart-items span.price,
  .cart-items dd.price,
  .cart-item__price-wrapper .price,
  .cart-item__price-wrapper span,
  .cart-item__totals .price,
  .cart-item__totals span,
  .cart-item__totals dd,
  .cart-item__details .product-option,
  .cart-item__details .product-option *,
  .cart-item__old-price,
  .cart-item__final-price,
  .product-option {
    font-style: normal !important;
    font-weight: 700 !important;
    font-size: 17px !important;
    color: #111 !important;
    letter-spacing: 0.03em !important;
    font-family: 'Inter', sans-serif !important;
  }

  .cart-item__details .product-option {
    font-size: 16px !important;
  }

  .product-option dt {
    font-weight: 500 !important;
    font-style: normal !important;
    color: #555 !important;
    font-size: 13px !important;
  }
  .product-option dd {
    font-weight: 600 !important;
    font-style: normal !important;
    color: #111 !important;
    font-size: 13px !important;
  }

  /* QUANTITY */
  .quantity__button {
    width: 44px !important;
    height: 44px !important;
  }
  .quantity__input {
    font-size: 16px !important;
    font-weight: 500 !important;
    font-style: normal !important;
  }

  /* Hide quantity popup */
  .quantity-popover__info,
  .cart-items__info,
  .quantity__rules,
  .quantity-popover__info-button {
    display: none !important;
  }

  /* IMAGE */
  .cart-item__media {
    vertical-align: top !important;
    padding-top: 0 !important;
    width: 160px !important;
  }
  .cart-item__image-container {
    width: 160px !important;
    height: 160px !important;
    overflow: hidden !important;
    display: block !important;
  }
  .cart-item__image {
    width: 160px !important;
    height: 160px !important;
    object-fit: contain !important;
    object-position: center center !important;
    display: block !important;
  }

  .cart-item__details,
  .cart-item__totals,
  .cart-item__quantity {
    vertical-align: top !important;
    padding-top: 4px !important;
  }

  .cart-item { margin-bottom: 36px !important; }

  /* TAX NOTE */
  .cart__tax-note {
    font-size: 12px !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
    color: #666 !important;
    font-style: normal !important;
  }
  .cart__tax-note a {
    pointer-events: none !important;
    text-decoration: none !important;
    color: inherit !important;
  }

  /* REMOVE BUTTON */
  cart-remove-button a,
  .cart-remove-button a {
    opacity: 0.5;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  cart-remove-button a:hover,
  .cart-remove-button a:hover { opacity: 1; }

  /* MONOGRAM BADGE */
  .nalvik-monogram-badge {
    display: inline-block;
    margin-top: 6px;
    padding: 4px 10px;
    font-size: 11px !important;
    letter-spacing: 0.15em !important;
    border: 1px solid #111;
    font-weight: 600 !important;
    background: #fafafa;
    text-transform: uppercase !important;
    font-style: normal !important;
  }

  /* =============================================
     EMPTY CART STYLING
  ============================================= */
  .cart__warnings {
    text-align: center !important;
    padding: 0 40px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    min-height: 70vh !important;
  }

  /* Cleaner than injecting a <style> tag conditionally in the markup:
     a single class toggled by Liquid, hiding the whole block in one shot
     with no extra reflow/flash. */
  .cart__warnings.cart__warnings--hidden {
    display: none !important;
  }

  .cart__empty-text {
    font-family: 'Inter', sans-serif !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    letter-spacing: 0.25em !important;
    text-transform: uppercase !important;
    color: #777777 !important;
    margin-bottom: 24px !important;
  }

  .cart__warnings .button {
    font-family: 'Inter', sans-serif !important;
    font-size: 10px !important;
    font-weight: 600 !important;
    letter-spacing: 0.22em !important;
    text-transform: uppercase !important;
    background: #111111 !important;
    color: #ffffff !important;
    border: none !important;
    padding: 16px 28px !important;
    height: auto !important;
    line-height: 1 !important;
    border-radius: 0 !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: opacity 0.2s !important;
    width: auto !important;
    white-space: nowrap !important;
  }

  .cart__warnings .button:hover {
    opacity: 0.75 !important;
  }

  .cart__login-title,
  .cart__login-paragraph {
    font-family: 'Inter', sans-serif !important;
    font-size: 11px !important;
    letter-spacing: 0.15em !important;
    text-transform: uppercase !important;
    color: #666 !important;
    margin-top: 24px !important;
  }

  /* ===== REMOVE POPUP ===== */
  #nalvik-remove-popup {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(255,255,255,0.97);
    z-index: 99999;
    align-items: center;
    justify-content: center;
  }
  #nalvik-remove-popup.active { display: flex; }
  .nrp-box {
    background: #fff;
    max-width: 480px;
    width: 92%;
    padding: 28px 32px 36px;
    position: relative;
    border: 1px solid #e8e8e8;
  }
  .nrp-header {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding-bottom: 16px;
    border-bottom: 1px solid #ddd;
    margin-bottom: 24px;
    font-style: normal;
    color: #000;
    font-family: 'Inter', sans-serif;
  }
  .nrp-close {
    position: absolute;
    top: 14px;
    right: 18px;
    font-size: 20px;
    background: none;
    border: none;
    cursor: pointer;
    color: #000;
    line-height: 1;
    font-weight: 300;
  }
  .nrp-body {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .nrp-body img {
    width: 100px;
    height: 100px;
    object-fit: contain;
    object-position: center;
    flex-shrink: 0;
  }
  .nrp-info h3 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-style: normal;
    margin: 0 0 6px;
    color: #000;
    font-family: 'Inter', sans-serif;
  }
  .nrp-info .nrp-variant {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #666;
    font-style: normal;
    margin: 0 0 8px;
    font-family: 'Inter', sans-serif;
  }
  .nrp-info .nrp-price {
    font-size: 17px;
    font-weight: 700;
    color: #000;
    font-style: normal;
    letter-spacing: 1px;
    margin: 0 0 20px;
    font-family: 'Inter', sans-serif;
  }
  .nrp-confirm {
    display: inline-block;
    padding: 13px 30px;
    background: #000;
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    font-weight: 700;
    font-style: normal;
    transition: opacity 0.2s;
    font-family: 'Inter', sans-serif;
  }
  .nrp-confirm:hover { opacity: 0.75; }
  @media (max-width: 560px) {
    .nrp-body { flex-direction: column; }
    .nrp-body img { width: 80px; height: 80px; }
    .nrp-box { padding: 24px 18px 28px; }
    .cart__warnings { padding: 80px 24px !important; }
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<cart-items class="gradient color-{{ section.settings.color_scheme }} isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}">
  <div class="page-width">

    <div class="title-wrapper-with-link">
      <h1 class="title title--primary">{{ 'sections.cart.title' | t }}</h1>
      <a href="/collections/edition-1" class="button">{{- 'general.continue_shopping' | t -}}</a>
    </div>

    {%- comment -%}
      Single Liquid-driven class instead of a conditionally-injected <style>
      block. Avoids an extra tag/reflow and is easier to reason about.
    {%- endcomment -%}
    <div class="cart__warnings{% if cart != empty %} cart__warnings--hidden{% endif %}">
      <h1 class="cart__empty-text">NO PIECES SELECTED</h1>
      <a href="/collections/edition-1" class="button">VIEW CURRENT EDITION</a>
      {%- if shop.customer_accounts_enabled and customer == null -%}
        <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
        <p class="cart__login-paragraph">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}
            <table class="cart-items">
              <caption class="visually-hidden">{{ 'sections.cart.title' | t }}</caption>
              <thead>
                <tr>
                  <th class="caption-with-letter-spacing" colspan="2" scope="col">{{ 'sections.cart.headings.product' | t }}</th>
                  <th class="medium-hide large-up-hide right caption-with-letter-spacing" colspan="1" scope="col">{{ 'sections.cart.headings.total' | t }}</th>
                  <th class="cart-items__heading--wide cart-items__heading--quantity small-hide caption-with-letter-spacing" colspan="1" scope="col">{{ 'sections.cart.headings.quantity' | t }}</th>
                  <th class="small-hide right caption-with-letter-spacing" colspan="1" scope="col">{{ 'sections.cart.headings.total' | t }}</th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                  <tr
                    class="cart-item"
                    id="CartItem-{{ item.index | plus: 1 }}"
                    data-item-title="{{ item.product.title | escape }}"
                    data-item-variant="{{ item.variant.title | escape }}"
                    data-item-price="{{ item.original_line_price | money }}"
                    data-item-image="{{ item.image | image_url: width: 300 }}"
                    data-item-remove-url="{{ item.url_to_remove }}"
                  >
                    <td class="cart-item__media">
                      {% if item.image %}
                        <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"> </a>
                        <div class="cart-item__image-container gradient global-media-settings">
                          <img
                            src="{{ item.image | image_url: width: 300 }}"
                            class="cart-item__image"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="160"
                            height="160"
                          >
                        </div>
                      {% endif %}
                    </td>

                    <td class="cart-item__details">
                      {%- if settings.show_vendor -%}
                        <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                      {%- endif -%}

                      <a href="{{ item.url }}" class="cart-item__name h4 break">{{ item.product.title | escape }}</a>

                      {%- if item.original_price != item.final_price -%}
                        <div class="cart-item__discounted-prices">
                          <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
                          <s class="cart-item__old-price product-option">{{- item.original_price | money -}}</s>
                          <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
                          <strong class="cart-item__final-price product-option">{{ item.final_price | money }}</strong>
                        </div>
                      {%- else -%}
                        <div class="product-option">{{ item.original_price | money }}</div>
                      {%- endif -%}

                      {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != null -%}
                        <dl>
                          {%- if item.product.has_only_default_variant == false -%}
                            {%- for option in item.options_with_values -%}
                              <div class="product-option">
                                <dt>{{ option.name }}:</dt>
                                <dd>{{ option.value }}</dd>
                              </div>
                            {%- endfor -%}
                          {%- endif -%}

                          {%- for property in item.properties -%}
                            {%- assign property_first_char = property.first | slice: 0 -%}
                            {%- if property.last != blank and property_first_char != '_' -%}
                              {%- assign prop_name_lower = property.first | downcase -%}
                              {%- if prop_name_lower contains 'monogram' -%}
                                <div class="product-option">
                                  <span class="nalvik-monogram-badge">{{ property.first | upcase }}: {{ property.last | upcase }}</span>
                                </div>
                              {%- else -%}
                                <div class="product-option">
                                  <dt>{{ property.first }}:</dt>
                                  <dd>
                                    {%- if property.last contains '/uploads/' -%}
                                      <a href="{{ property.last }}" class="link" target="_blank">{{ property.last | split: '/' | last }}</a>
                                    {%- else -%}
                                      {{ property.last }}
                                    {%- endif -%}
                                  </dd>
                                </div>
                              {%- endif -%}
                            {%- endif -%}
                          {%- endfor -%}
                        </dl>
                        <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}

                      <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                        {%- for discount in item.line_level_discount_allocations -%}
                          <li class="discounts__discount">
                            {{- 'icon-discount.svg' | inline_asset_content -}}
                            {{ discount.discount_application.title | escape }}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </td>

                    <td class="cart-item__totals right medium-hide large-up-hide">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                        {%- if item.original_line_price != item.final_line_price -%}
                          <dl class="cart-item__discounted-prices">
                            <dt class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</dt>
                            <dd><s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s></dd>
                            <dt class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</dt>
                            <dd class="price price--end">{{ item.final_line_price | money }}</dd>
                          </dl>
                        {%- else -%}
                          <span class="price price--end">{{ item.original_line_price | money }}</span>
                        {%- endif -%}
                        {%- if item.variant.available and item.unit_price_measurement -%}
                          {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                        {%- endif -%}
                      </div>
                    </td>

                    <td class="cart-item__quantity">
                      <quantity-popover>
                        <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                          <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">{{ 'products.product.quantity.label' | t }}</label>
                          <div class="quantity-popover-container">
                            <quantity-input class="quantity cart-quantity">
                              <button class="quantity__button" name="minus" type="button">
                                <span class="visually-hidden">{{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}</span>
                                <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                              </button>
                              <input
                                class="quantity__input"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                type="number"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                min="0"
                                step="1"
                                aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                id="Quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                              <button class="quantity__button" name="plus" type="button">
                                <span class="visually-hidden">{{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}</span>
                                <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                              </button>
                            </quantity-input>
                          </div>

                          <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                            <a
                              href="{{ item.url_to_remove }}"
                              class="button button--tertiary"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                            >
                              <span class="svg-wrapper">{{- 'icon-remove.svg' | inline_asset_content -}}</span>
                            </a>
                          </cart-remove-button>
                        </div>

                        <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                          <small class="cart-item__error-text"></small>
                          <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                        </div>
                      </quantity-popover>
                    </td>

                    <td class="cart-item__totals right small-hide">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                        {%- if item.original_line_price != item.final_line_price -%}
                          <dl class="cart-item__discounted-prices">
                            <dt class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</dt>
                            <dd><s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s></dd>
                            <dt class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</dt>
                            <dd class="price price--end">{{ item.final_line_price | money }}</dd>
                          </dl>
                        {%- else -%}
                          <span class="price price--end">{{ item.original_line_price | money }}</span>
                        {%- endif -%}
                        {%- if item.variant.available and item.unit_price_measurement -%}
                          {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                        {%- endif -%}
                      </div>
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- endif -%}
        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
    </form>
  </div>

  <!-- REMOVE POPUP -->
  <div id="nalvik-remove-popup" role="dialog" aria-modal="true">
    <div class="nrp-box">
      <button class="nrp-close" id="nrp-close-btn" aria-label="Close">&#10005;</button>
      <p class="nrp-header">Remove Item?</p>
      <div class="nrp-body">
        <img id="nrp-image" src="" alt="" />
        <div class="nrp-info">
          <h3 id="nrp-title"></h3>
          <p class="nrp-variant" id="nrp-variant"></p>
          <p class="nrp-price" id="nrp-price"></p>
          <button class="nrp-confirm" id="nrp-confirm-btn">Yes, Remove</button>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function () {
    var popup      = document.getElementById('nalvik-remove-popup');
    var confirmBtn = document.getElementById('nrp-confirm-btn');
    var closeBtn   = document.getElementById('nrp-close-btn');
    var pendingRemoveLink = null;

    function openPopup(row) {
      document.getElementById('nrp-title').textContent   = row.dataset.itemTitle || '';
      var v = row.dataset.itemVariant || '';
      document.getElementById('nrp-variant').textContent = (v && v !== 'Default Title') ? v : '';
      document.getElementById('nrp-price').textContent   = row.dataset.itemPrice  || '';
      document.getElementById('nrp-image').src           = row.dataset.itemImage  || '';
      popup.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      popup.classList.remove('active');
      document.body.style.overflow = '';
      pendingRemoveLink = null;
    }

    function bindMinusButtons() {
      document.querySelectorAll('.quantity__button[name="minus"]').forEach(function (btn) {
        var fresh = btn.cloneNode(true);
        btn.parentNode.replaceChild(fresh, btn);

        fresh.addEventListener('click', function (e) {
          var qInput = this.closest('quantity-input').querySelector('.quantity__input');
          if (!qInput) return;

          var current = parseInt(qInput.value, 10);
          if (current > 1) return;

          e.preventDefault();
          e.stopImmediatePropagation();

          var row = this.closest('tr.cart-item');
          if (!row) return;

          var removeLink = row.querySelector('cart-remove-button a');
          if (removeLink) {
            pendingRemoveLink = removeLink;
            openPopup(row);
          }
        }, true);
      });
    }

    confirmBtn.addEventListener('click', function () {
      if (pendingRemoveLink) pendingRemoveLink.click();
      closePopup();
    });

    closeBtn.addEventListener('click', closePopup);
    popup.addEventListener('click', function (e) { if (e.target === popup) closePopup(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closePopup(); });

    document.addEventListener('DOMContentLoaded', bindMinusButtons);
    document.addEventListener('cart:updated', function () { setTimeout(bindMinusButtons, 400); });
  })();
  </script>
</cart-items>

