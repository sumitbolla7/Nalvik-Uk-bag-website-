<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&display=swap" rel="stylesheet">

<style>
  .nf2-section {
    position: relative;
    width: 100%;
    background: #ffffff;
    overflow: hidden;
    aspect-ratio: 16 / 2;
    min-height: 420px;
  }

  .nf2-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .nf2-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(100%);
  }

  .nf2-label {
    position: absolute;
    bottom: 40px;
    right: 60px;
    text-align: right;
  }

  .nf2-label a {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
    display: inline-block;
  }

  .nf2-label a:hover {
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .nf2-section {
      aspect-ratio: 4 / 5;
      min-height: 500px;
    }
    .nf2-label {
      bottom: 28px;
      right: 24px;
    }
    .nf2-label a {
      font-size: 11px;
    }
  }
</style>

<div class="nf2-section">
  <div class="nf2-image">
    <img
      src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/Untitled_design_4.png"
      alt="Founder's Edition"
      width="1400"
      height="600"
      loading="lazy"
    >
  </div>
  <div class="nf2-label">
    <a href="/collections/edition-1">Founder's Edition</a>
  </div>
</div>

{% schema %}
{
  "name": "NALVIK Founders",
  "tag": "section",
  "class": "nalvik-founders",
  "settings": [],
  "presets": [{ "name": "NALVIK Founders" }]
}
{% endschema %}
