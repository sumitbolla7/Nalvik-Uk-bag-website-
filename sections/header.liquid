<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

<style>
  header-drawer { justify-self: start; margin-left: -1.2rem; }
  .list-menu { list-style: none; padding: 0; margin: 0; }
  .list-menu--inline { display: inline-flex; flex-wrap: wrap; }
  .list-menu__item { display: flex; align-items: center; }
  .list-menu__item--link { text-decoration: none; padding: 0.5rem 0; }

  .nalvik-header-wrapper {
    width: 100%;
    z-index: 9999;
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.3s ease;
  }

  /* ================= HOMEPAGE HEADER (Transparent + White Text) ================= */
  .nalvik-header-wrapper.is-homepage {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
  }

  .nalvik-header-wrapper.is-homepage.scrolled {
    background: #ffffff !important;
    box-shadow: 0 1px 12px rgba(0,0,0,0.06) !important;
  }

  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-logo span,
  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-nav-link,
  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-mobile-logo span {
    color: #ffffff !important;
  }

  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-hamburger span {
    background: #ffffff !important;
  }

  /* Force Cart and Cart Count badge to stay white on Homepage */
  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-cart,
  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-cart * {
    color: #ffffff !important;
  }

  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-cart-count {
    background: #ffffff !important;
    color: #000000 !important;
  }

  /* ================= OTHER PAGES HEADER (White Bg + Black Text) ================= */
  .nalvik-header-wrapper:not(.is-homepage) {
    position: sticky !important;
    top: 0 !important;
    background: #ffffff !important;
    box-shadow: 0 1px 12px rgba(0,0,0,0.06) !important;
  }

  .nalvik-header-wrapper:not(.is-homepage) .nalvik-logo span,
  .nalvik-header-wrapper:not(.is-homepage) .nalvik-nav-link,
  .nalvik-header-wrapper:not(.is-homepage) .nalvik-mobile-logo span,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-logo span,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-nav-link,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-mobile-logo span {
    color: #000000 !important;
  }

  .nalvik-header-wrapper:not(.is-homepage) .nalvik-hamburger span,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-hamburger span {
    background: #000000 !important;
  }

  .nalvik-header-wrapper:not(.is-homepage) .nalvik-cart,
  .nalvik-header-wrapper:not(.is-homepage) .nalvik-cart *,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-cart,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-cart * {
    color: #000000 !important;
  }

  .nalvik-header-wrapper:not(.is-homepage) .nalvik-cart-count,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-cart-count {
    background: #000000 !important;
    color: #ffffff !important;
  }

  .nalvik-header-wrapper.hide-header {
    transform: translateY(-100%);
  }

  .section-header {
    position: sticky !important;
    top: 0;
    z-index: 9999;
  }

  .nalvik-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 22px 48px;
  }

  .nalvik-left-group {
    display: flex;
    align-items: center;
    gap: 56px;
  }

  .nalvik-logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .nalvik-logo-img {
    height: 24px;
    width: auto;
    display: block;
    transition: filter 0.25s ease;
  }

  .nalvik-header-wrapper.is-homepage:not(.scrolled) .nalvik-logo-img {
    filter: none !important;
  }

  .nalvik-header-wrapper:not(.is-homepage) .nalvik-logo-img,
  .nalvik-header-wrapper.is-homepage.scrolled .nalvik-logo-img {
    filter: invert(1) !important;
  }

  @media (max-width: 768px) {
    .nalvik-logo-img {
      height: 20px;
    }
  }

  .nalvik-nav-left {
    display: flex;
    align-items: center;
    gap: 56px;
  }

  .nalvik-nav-right {
    display: flex;
    align-items: center;
    gap: 56px;
  }

  .nalvik-nav-link {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.25s ease, opacity 0.2s;
    white-space: nowrap;
  }

  .nalvik-nav-link:hover { opacity: 0.6; }

  .nalvik-cart { position: relative; }

  .nalvik-cart-count {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 16px !important;
    height: 16px !important;
    border-radius: 50% !important;
    background: #000000 !important;
    color: #ffffff !important;
    font-size: 9px !important;
    font-weight: 700 !important;
    margin-left: 6px !important;
    position: static !important;
    transform: none !important;
    vertical-align: middle !important;
    line-height: 1 !important;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .nalvik-mobile-header {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    position: relative;
  }

  .nalvik-mobile-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    text-decoration: none;
    z-index: 2;
  }

  .nalvik-mobile-logo span {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    font-size: 18px;
    letter-spacing: 0.28em;
    font-weight: 700;
    text-transform: uppercase;
    transition: color 0.25s ease;
  }

  .nalvik-hamburger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .nalvik-hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    transition: background 0.25s ease, transform 0.3s;
  }

  .nalvik-drawer {
    display: none;
    position: fixed;
    top: 58px; /* Height of mobile header */
    left: 0;
    width: 100%;
    height: calc(100vh - 58px);
    background: #ffffff !important;
    z-index: 9998;
    flex-direction: column;
    padding: 50px 30px 40px;
    box-sizing: border-box;
  }
  
  .nalvik-drawer.is-open {
    display: flex !important;
  }

  .nalvik-drawer__nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: auto;
    text-align: left;
  }

  .nalvik-drawer__nav .nalvik-nav-link {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif !important;
    font-size: 26px !important;
    font-weight: 500 !important;
    letter-spacing: 0.05em !important;
    color: #000000 !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    line-height: 1.2 !important;
    opacity: 1 !important;
  }

  .nalvik-drawer__footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    margin-top: 30px;
  }

  .nalvik-drawer__footer-left {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-align: left;
  }

  .nalvik-drawer__footer-link {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    letter-spacing: 0.08em !important;
    color: #000000 !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
  }

  .nalvik-drawer__footer-link.underline {
    text-decoration: underline !important;
    text-underline-offset: 4px;
  }

  .nalvik-drawer__footer-right {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif !important;
    font-size: 8px !important;
    font-weight: 600 !important;
    letter-spacing: 0.1em !important;
    color: #888888 !important;
    text-align: right;
    line-height: 1.5;
    text-transform: uppercase;
  }

  @media (max-width: 989px) {
    .nalvik-mobile-header {
      display: flex !important;
    }
    .nalvik-header {
      display: none !important;
    }
  }

  @media screen and (max-width: 989px) {
    .nalvik-header { display: none; }
    .nalvik-mobile-header { display: flex; }
  }

  @media screen and (min-width: 990px) {
    .nalvik-mobile-header { display: none; }
    .nalvik-drawer { display: none !important; }
  }

  /* ===== DRAWER LINKS ALWAYS BLACK — MUST BE LAST ===== */
  #NalvikDrawer .nalvik-nav-link,
  #NalvikDrawer a {
    color: #000000 !important;
    opacity: 1 !important;
  }
</style>


