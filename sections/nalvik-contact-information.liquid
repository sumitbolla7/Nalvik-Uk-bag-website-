<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  .contact-info-page {
    width: 100%;
    background: #ffffff;
    padding: 80px 24px 100px;
    box-sizing: border-box;
  }

  .contact-info-container {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 70px;
  }

  .contact-info-block {
    text-align: left;
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 50px;
  }
  
  .contact-info-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-info-heading {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #000000;
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .contact-info-body {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a1a1a;
    line-height: 2;
    margin-bottom: 28px;
  }

  .contact-info-btn {
    display: inline-block;
    padding: 16px 48px;
    background: #000000;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    min-width: 200px;
    box-sizing: border-box;
  }

  .contact-info-btn:hover {
    background: #333333;
  }

  @media (max-width: 749px) {
    .contact-info-btn {
      width: 100%;
      display: block;
    }
  }
</style>

<div class="contact-info-page">
  <div class="contact-info-container">

    <!-- FAQ Block -->
    <div class="contact-info-block">
      <h2 class="contact-info-heading">FREQUENTLY ASKED QUESTIONS</h2>
      <p class="contact-info-body">
        YOU CAN ALSO USE THIS AREA TO CONSULT THE FAQ'S, FOLLOW YOUR ORDER AND TRACK YOUR RETURN.
      </p>
      <a href="/pages/faq" class="contact-info-btn">FAQ</a>
    </div>

    <!-- Call Us Block -->
    <div class="contact-info-block">
      <h2 class="contact-info-heading">CALL US</h2>
      <p class="contact-info-body">
        SPEAK TO ONE OF OUR AMBASSADORS AT:<br>
        +91 9955800734<br>
        MON-SAT 9AM-7PM EST
      </p>
      <a href="tel:+919955800734" class="contact-info-btn">CALL US</a>
    </div>

    <!-- Email Block -->
    <div class="contact-info-block">
      <h2 class="contact-info-heading">EMAIL</h2>
      <p class="contact-info-body">
        WE STRIVE TO REPLY TO YOU WITHIN 48H DURING BUSINESS DAYS.
      </p>
      <a href="mailto:care@nalvik.com" class="contact-info-btn">EMAIL US</a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Contact Information",
  "tag": "section",
  "class": "contact-information-section",
  "settings": [],
  "presets": [
    {
      "name": "Contact Information"
    }
  ]
}
{% endschema %}
