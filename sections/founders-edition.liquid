{% comment %}
  NALVIK — Founder's Edition (Stacked Responsive Layout)
{% endcomment %}

<style>
  .fe-stacked-wrap * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .fe-stacked {
    display: block;
    background: #ffffff;
  }

  .fe-stacked__header {
    text-align: center;
    padding: 36px 20px 28px;
  }

  @media screen and (min-width: 750px) {
    .fe-stacked__header {
      padding: 60px 40px 40px;
    }
  }

  .fe-stacked__title {
    font-family: var(--font-heading-family), Georgia, 'Times New Roman', serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #000;
  }

  @media screen and (min-width: 750px) {
    .fe-stacked__title {
      font-size: 16px;
      letter-spacing: 0.32em;
    }
  }

  .fe-stacked__stack {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fe-stacked__item {
    position: relative;
    display: block;
    width: 100%;
    line-height: 0;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .fe-stacked__item {
      height: 80vh;
      max-height: 700px;
      min-height: 500px;
    }
  }

  .fe-stacked__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .fe-stacked__item:hover img {
    transform: scale(1.03);
  }

  .fe-stacked__label {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 2;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #1a1a1a;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .fe-stacked__label {
      top: 40px;
      left: 40px;
      font-size: 13px;
      letter-spacing: 0.22em;
    }
  }
</style>

{%- liquid
  assign crescent_cdn = 'https://cdn.shopify.com/s/files/1/0812/9626/1360/files/crescent_bag_image_mobile_1.png?v=1779820365'
  assign obsidian_cdn = 'https://cdn.shopify.com/s/files/1/0812/9626/1360/files/obsidian_mobile_pic_1.png?v=1779820366'
  assign duffle_cdn = 'https://cdn.shopify.com/s/files/1/0812/9626/1360/files/duffle_bag_pic.png?v=1779820365'
-%}

<div class="fe-stacked-wrap">
  <div class="fe-stacked">
    <header class="fe-stacked__header">
      <h1 class="fe-stacked__title">{{ section.settings.mobile_title | default: "THE FOUNDERS EDITION" }}</h1>
    </header>

    <div class="fe-stacked__stack">
      <!-- 1. The Crescent -->
      <a href="{{ section.settings.mobile_1_link | default: '#' }}" class="fe-stacked__item">
        <span class="fe-stacked__label">{{ section.settings.mobile_1_name | default: 'THE CRESCENT' }}</span>
        {% if section.settings.mobile_1_image != blank %}
          <img src="{{ section.settings.mobile_1_image | image_url: width: 2000 }}" alt="{{ section.settings.mobile_1_name }}" width="2000" loading="eager">
        {% elsif section.settings.desktop_1_image != blank %}
          <img src="{{ section.settings.desktop_1_image | image_url: width: 2000 }}" alt="{{ section.settings.mobile_1_name }}" width="2000" loading="eager">
        {% else %}
          <img src="{{ crescent_cdn }}" alt="The Crescent" width="2000" loading="eager">
        {% endif %}
      </a>

      <!-- 2. The Obsidian -->
      <a href="{{ section.settings.mobile_2_link | default: '#' }}" class="fe-stacked__item">
        <span class="fe-stacked__label">{{ section.settings.mobile_2_name | default: 'THE OBSIDIAN' }}</span>
        {% if section.settings.mobile_2_image != blank %}
          <img src="{{ section.settings.mobile_2_image | image_url: width: 2000 }}" alt="{{ section.settings.mobile_2_name }}" width="2000" loading="lazy">
        {% elsif section.settings.desktop_2_image != blank %}
          <img src="{{ section.settings.desktop_2_image | image_url: width: 2000 }}" alt="{{ section.settings.mobile_2_name }}" width="2000" loading="lazy">
        {% else %}
          <img src="{{ obsidian_cdn }}" alt="The Obsidian" width="2000" loading="lazy">
        {% endif %}
      </a>

      <!-- 3. The Traverse -->
      <a href="{{ section.settings.mobile_3_link | default: '#' }}" class="fe-stacked__item">
        <span class="fe-stacked__label">{{ section.settings.mobile_3_name | default: 'THE TRAVERSE' }}</span>
        {% if section.settings.mobile_3_image != blank %}
          <img src="{{ section.settings.mobile_3_image | image_url: width: 2000 }}" alt="{{ section.settings.mobile_3_name }}" width="2000" loading="lazy">
        {% elsif section.settings.desktop_3_image != blank %}
          <img src="{{ section.settings.desktop_3_image | image_url: width: 2000 }}" alt="{{ section.settings.mobile_3_name }}" width="2000" loading="lazy">
        {% else %}
          <img src="{{ duffle_cdn }}" alt="The Traverse" width="2000" loading="lazy">
        {% endif %}
      </a>
    </div>
  </div>
</div>

