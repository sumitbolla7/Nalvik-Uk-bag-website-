{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{% if page.handle == 'faq' %}
  {% render 'faq-template-content' %}
{% elsif page.handle == 'contact' or page.handle == 'contact-us' or page.handle == 'contact-information' %}
  {% render 'contact-template-content' %}
{% elsif page.handle == 'access' or page.handle == 'acess' or page.handle == 'login' or page.handle == 'authentication' %}
  {% render 'access-template-content' %}
{% elsif page.handle == 'refund-policy' or page.handle == 'refunds' %}
  {% render 'refund-policy-template-content' %}
{% elsif page.handle == 'privacy-policy' or page.handle == 'privacy' %}
  {% render 'privacy-policy-template-content' %}
{% elsif page.handle == 'shipping-policy' or page.handle == 'shipping' %}
  {% render 'shipping-policy-template-content' %}
{% else %}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="page-width page-width--narrow section-{{ section.id }}-padding">
    <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}" style="text-align: center;">
      {{ page.title | escape }}
    </h1>
    <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ page.content }}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
