{% comment %}
  NALVIK — About/Craftsmanship page
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
  }

  .nalvik-about-page--{{ section.id }} {
    background: #ffffff;
    width: 100%;
    font-family: 'Montserrat', sans-serif;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__hero {
    width: 100%;
    line-height: 0;
    background: #eceae6;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__hero img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 10px;
    padding: 0;
    align-items: start;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__col {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__col--right {
    margin-top: 72px;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__media {
    width: 100%;
    line-height: 0;
    background: #eceae6;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__media img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__media--tall img {
    aspect-ratio: 3 / 4;
    min-height: 220px;
    object-fit: cover;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__block {
    padding: 20px 10px 28px;
    text-align: left;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600; /* Bold/semi-bold */
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .nalvik-about-page--{{ section.id }} .nalvik-about-page__body {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.1em;
    line-height: 1.65;
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .nalvik-about-page--{{ section.id }} .nalvik-about-page__grid {
      max-width: 900px;
      margin: 0 auto;
      column-gap: 24px;
      padding: 0 40px 60px;
    }

    .nalvik-about-page--{{ section.id }} .nalvik-about-page__col--right {
      margin-top: 120px;
    }

    .nalvik-about-page--{{ section.id }} .nalvik-about-page__block {
      padding: 28px 16px 40px;
    }

    .nalvik-about-page--{{ section.id }} .nalvik-about-page__heading {
      font-size: 12px;
    }

    .nalvik-about-page--{{ section.id }} .nalvik-about-page__body {
      font-size: 10px;
      line-height: 1.75;
    }

    .nalvik-about-page--{{ section.id }} .nalvik-about-page__hero {
      max-width: 900px;
      margin: 0 auto;
    }
  }
{%- endstyle -%}

<section class="nalvik-about-page nalvik-about-page--{{ section.id }}" aria-label="About NALVIK">
  <div class="nalvik-about-page__hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1600 }}"
        alt="{{ section.settings.hero_image.alt | default: 'NALVIK craftsmanship' | escape }}"
        width="1600"
        height="{{ 1600 | divided_by: section.settings.hero_image.aspect_ratio | round }}"
        loading="eager"
      >
    {%- else -%}
      <img
        src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/first_image.png?v=1781546314"
        alt="NALVIK craftsmanship"
        width="1600"
        height="1000"
        loading="eager"
      >
    {%- endif -%}
  </div>

  <div class="nalvik-about-page__grid">
    <div class="nalvik-about-page__col nalvik-about-page__col--left">
      <div class="nalvik-about-page__media">
        {%- if section.settings.image_mission != blank -%}
          <img src="{{ section.settings.image_mission | image_url: width: 800 }}" alt="" width="800" height="800" loading="lazy">
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/Our_mission_image_2nd.png?v=1781546416" alt="OUR MISSION" width="800" height="800" loading="lazy">
        {%- endif -%}
      </div>

      <div class="nalvik-about-page__block">
        <h2 class="nalvik-about-page__heading">{{ section.settings.mission_heading | default: 'OUR MISSION' }}</h2>
        <p class="nalvik-about-page__body">
          {%- if section.settings.mission_text != blank -%}
            {{ section.settings.mission_text | newline_to_br }}
          {%- else -%}
            NALVIK WAS NOT CREATED TO CHASE SEASONS, ALGORITHMS, OR VOLUME.<br>
            IT BEGAN WITH A SIMPLE IDEA:<br>
            FEWER THINGS, MADE WITH INTENTION, CARRY<br>
            MORE MEANING.<br>
            IN A WORLD OF EXCESS AND SPEED, WE CHOSE RESTRAINT.
          {%- endif -%}
        </p>
      </div>

      <div class="nalvik-about-page__media">
        {%- if section.settings.image_pricing != blank -%}
          <img src="{{ section.settings.image_pricing | image_url: width: 800 }}" alt="" width="800" height="800" loading="lazy">
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/why_price_this_waty_4th_iamge.png?v=1781546481" alt="WHY WE PRICE THIS WAY" width="800" height="800" loading="lazy">
        {%- endif -%}
      </div>

      <div class="nalvik-about-page__block">
        <h2 class="nalvik-about-page__heading">{{ section.settings.pricing_heading | default: 'WHY WE PRICE THIS WAY' }}</h2>
        <p class="nalvik-about-page__body">
          {%- if section.settings.pricing_text != blank -%}
            {{ section.settings.pricing_text | newline_to_br }}
          {%- else -%}
            OUR PRICING REFLECTS INTENTION, NOT<br>
            COMPARISON.<br>
            IT ALLOWS US TO WORK WITHOUT<br>
            COMPROMISE, REMAIN INDEPENDENT,<br>
            AND PROTECT THE INTEGRITY OF WHAT WE<br>
            MAKE. WE DO NOT DISCOUNT. WE DO NOT OVERPRODUCE.
          {%- endif -%}
        </p>
      </div>
    </div>

    <div class="nalvik-about-page__col nalvik-about-page__col--right">
      <div class="nalvik-about-page__media nalvik-about-page__media--tall">
        {%- if section.settings.image_create != blank -%}
          <img src="{{ section.settings.image_create | image_url: width: 800 }}" alt="" width="800" height="1067" loading="lazy">
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/how_we_create_3rd_image.png?v=1781546443" alt="HOW WE CREATE" width="800" height="1067" loading="lazy">
        {%- endif -%}
      </div>

      <div class="nalvik-about-page__block">
        <h2 class="nalvik-about-page__heading">{{ section.settings.create_heading | default: 'HOW WE CREATE' }}</h2>
        <p class="nalvik-about-page__body">
          {%- if section.settings.create_text != blank -%}
            {{ section.settings.create_text | newline_to_br }}
          {%- else -%}
            NALVIK PIECES ARE PRODUCED IN LIMITED NUMBERS, IN OUR OWN ATELIER.<br>
            EVERY DECISION — FROM MATERIAL SELECTION TO FINISHING — IS DELIBERATE. WE WORK IN SMALL BATCHES, NOT BECAUSE WE CANNOT MAKE MORE,<br>
            BUT BECAUSE MAKING MORE WOULD DILUTE WHAT MATTERS.<br>
            EACH DESIGN IS RELEASED ONCE. NO RE-RUNS. NO EXCESS.
          {%- endif -%}
        </p>
      </div>

      <div class="nalvik-about-page__media nalvik-about-page__media--tall">
        {%- if section.settings.image_who != blank -%}
          <img src="{{ section.settings.image_who | image_url: width: 800 }}" alt="" width="800" height="1067" loading="lazy">
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/whos_this_for.png?v=1781546509" alt="WHO THIS IS FOR" width="800" height="1067" loading="lazy">
        {%- endif -%}
      </div>

      <div class="nalvik-about-page__block">
        <h2 class="nalvik-about-page__heading">{{ section.settings.who_heading | default: 'WHO THIS IS FOR' }}</h2>
        <p class="nalvik-about-page__body">
          {%- if section.settings.who_text != blank -%}
            {{ section.settings.who_text | newline_to_br }}
          {%- else -%}
            NALVIK IS FOR THOSE WHO VALUE DISCRETION OVER DISPLAY.<br>
            FOR THOSE WHO NOTICE FORM BEFORE BRANDING.<br>
            FOR THOSE WHO PREFER FEWER OBJECTS, CHOSEN WELL.
          {%- endif -%}
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nalvik About Page",
  "tag": "section",
  "class": "nalvik-about-page-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (top)"
    },
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "image_picker",
      "id": "image_mission",
      "label": "Image above Our Mission"
    },
    {
      "type": "text",
      "id": "mission_heading",
      "label": "Mission heading",
      "default": "OUR MISSION"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission text",
      "default": "NALVIK WAS NOT CREATED TO CHASE SEASONS, ALGORITHMS, OR VOLUME.\nIT BEGAN WITH A SIMPLE IDEA:\nFEWER THINGS, MADE WITH INTENTION, CARRY\nMORE MEANING.\nIN A WORLD OF EXCESS AND SPEED, WE CHOSE RESTRAINT."
    },
    {
      "type": "image_picker",
      "id": "image_pricing",
      "label": "Image above Why We Price"
    },
    {
      "type": "text",
      "id": "pricing_heading",
      "label": "Pricing heading",
      "default": "WHY WE PRICE THIS WAY"
    },
    {
      "type": "textarea",
      "id": "pricing_text",
      "label": "Pricing text",
      "default": "OUR PRICING REFLECTS INTENTION, NOT\nCOMPARISON.\nIT ALLOWS US TO WORK WITHOUT\nCOMPROMISE, REMAIN INDEPENDENT,\nAND PROTECT THE INTEGRITY OF WHAT WE\nMAKE. WE DO NOT DISCOUNT. WE DO NOT OVERPRODUCE."
    },
    {
      "type": "header",
      "content": "Right column"
    },
    {
      "type": "image_picker",
      "id": "image_create",
      "label": "Image above How We Create"
    },
    {
      "type": "text",
      "id": "create_heading",
      "label": "Create heading",
      "default": "HOW WE CREATE"
    },
    {
      "type": "textarea",
      "id": "create_text",
      "label": "Create text",
      "default": "NALVIK PIECES ARE PRODUCED IN LIMITED NUMBERS, IN OUR OWN ATELIER.\nEVERY DECISION — FROM MATERIAL SELECTION TO FINISHING — IS DELIBERATE. WE WORK IN SMALL BATCHES, NOT BECAUSE WE CANNOT MAKE MORE,\nBUT BECAUSE MAKING MORE WOULD DILUTE WHAT MATTERS.\nEACH DESIGN IS RELEASED ONCE. NO RE-RUNS. NO EXCESS."
    },
    {
      "type": "image_picker",
      "id": "image_who",
      "label": "Image above Who This Is For"
    },
    {
      "type": "text",
      "id": "who_heading",
      "label": "Who heading",
      "default": "WHO THIS IS FOR"
    },
    {
      "type": "textarea",
      "id": "who_text",
      "label": "Who text",
      "default": "NALVIK IS FOR THOSE WHO VALUE DISCRETION OVER DISPLAY.\nFOR THOSE WHO NOTICE FORM BEFORE BRANDING.\nFOR THOSE WHO PREFER FEWER OBJECTS, CHOSEN WELL."
    }
  ],
  "presets": [{ "name": "Nalvik About Page" }]
}
{% endschema %}
