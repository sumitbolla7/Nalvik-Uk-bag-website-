{% comment %}
  NALVIK — Craftsmanship full-width video + centered NALVIK logo
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
  }

  .nalvik-craft--{{ section.id }} {
    position: relative;
    width: 100%;
    height: min(55vh, 640px);
    min-height: 400px;
    overflow: hidden;
    background: #111;
  }

  .nalvik-craft--{{ section.id }} .nalvik-craft__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .nalvik-craft--{{ section.id }} .nalvik-craft__media video,
  .nalvik-craft--{{ section.id }} .nalvik-craft__media img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center;
    display: block;
  }

  .nalvik-craft--{{ section.id }} .nalvik-craft__logo {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    letter-spacing: 0.32em;
    text-indent: 0.32em;
    color: #ffffff;
    text-transform: uppercase;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.25);
  }
{%- endstyle -%}

<section class="nalvik-craft nalvik-craft--{{ section.id }}" aria-label="Craftsmanship">
  <div class="nalvik-craft__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'nalvik-craft__video' }}
    {%- elsif section.settings.video_url != blank -%}
      <video autoplay muted loop playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.poster_image != blank -%}
      <img
        src="{{ section.settings.poster_image | image_url: width: 1920 }}"
        alt="{{ section.settings.poster_image.alt | escape }}"
        width="1920"
        height="1080"
        loading="lazy"
      >
    {%- endif -%}
  </div>
 {% comment %} <p class="nalvik-craft__logo">{{ section.settings.logo_text | default: 'NALVIK' }}</p>{% endcomment %}
</section>

{% schema %}
{
  "name": "Nalvik Craft Video",
  "tag": "section",
  "class": "nalvik-craft-section",
  "enabled_on": { "templates": ["index"] },
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4 fallback)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image (fallback)"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Center logo text",
      "default": "NALVIK"
    }
  ],
  "presets": [{ "name": "Nalvik Craft Video" }]
}
{% endschema %}
