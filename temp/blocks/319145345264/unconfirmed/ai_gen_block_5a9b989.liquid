{% doc %}
  @prompt
    Add a custom CSS rule to make all text in the footer section uppercase using text-transform: uppercase. Target the footer section specifically without affecting other parts of the theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-uppercase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  {% if block.settings.target_scope == 'footer_section' %}
    .footer {
      text-transform: uppercase;
    }
  {% elsif block.settings.target_scope == 'footer_custom' %}
    {{ block.settings.custom_selector }} {
      text-transform: uppercase;
    }
  {% endif %}

  {% if block.settings.apply_to_links %}
    {% if block.settings.target_scope == 'footer_section' %}
      .footer a {
        text-transform: uppercase;
      }
    {% elsif block.settings.target_scope == 'footer_custom' %}
      {{ block.settings.custom_selector }} a {
        text-transform: uppercase;
      }
    {% endif %}
  {% endif %}

  {% if block.settings.apply_to_headings %}
    {% if block.settings.target_scope == 'footer_section' %}
      .footer h1,
      .footer h2,
      .footer h3,
      .footer h4,
      .footer h5,
      .footer h6 {
        text-transform: uppercase;
      }
    {% elsif block.settings.target_scope == 'footer_custom' %}
      {{ block.settings.custom_selector }} h1,
      {{ block.settings.custom_selector }} h2,
      {{ block.settings.custom_selector }} h3,
      {{ block.settings.custom_selector }} h4,
      {{ block.settings.custom_selector }} h5,
      {{ block.settings.custom_selector }} h6 {
        text-transform: uppercase;
      }
    {% endif %}
  {% endif %}

  {% if block.settings.letter_spacing > 0 %}
    {% if block.settings.target_scope == 'footer_section' %}
      .footer {
        letter-spacing: {{ block.settings.letter_spacing }}px;
      }
    {% elsif block.settings.target_scope == 'footer_custom' %}
      {{ block.settings.custom_selector }} {
        letter-spacing: {{ block.settings.letter_spacing }}px;
      }
    {% endif %}
  {% endif %}
{% endstyle %}

<div class="ai-footer-uppercase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_info %}
    <div style="padding: 20px; background-color: #f4f4f4; border-radius: 4px; text-align: center; font-size: 14px; color: #666;">
      Footer text transform applied: <strong>UPPERCASE</strong>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Footer uppercase CSS",
  "settings": [
    {
      "type": "header",
      "content": "Target settings"
    },
    {
      "type": "select",
      "id": "target_scope",
      "label": "Target scope",
      "options": [
        {
          "value": "footer_section",
          "label": "Footer section (.footer)"
        },
        {
          "value": "footer_custom",
          "label": "Custom selector"
        }
      ],
      "default": "footer_section"
    },
    {
      "type": "text",
      "id": "custom_selector",
      "label": "Custom CSS selector",
      "default": ".footer"
    },
    {
      "type": "header",
      "content": "Additional options"
    },
    {
      "type": "checkbox",
      "id": "apply_to_links",
      "label": "Apply to links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "apply_to_headings",
      "label": "Apply to headings",
      "default": true
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "checkbox",
      "id": "show_info",
      "label": "Show info message",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Footer uppercase CSS"
    }
  ]
}
{% endschema %}
