<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  .cert-outer {
    background: linear-gradient(90deg, #d9d7d3 0%, #e5e4e1 45%, #f1f1ef 100%);
    width: 100%;
    padding: 60px 60px 120px 60px;
    position: relative;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 0;
    align-items: start;
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    min-height: 500px;
  }

  /* ── LEFT ── */
  .col-left {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: 20px;
    z-index: 2;
    position: relative;
  }

  .cert-tagline {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #1a1a1a;
    line-height: 2;
    max-width: 340px;
    white-space: normal;
  }

  .cert-info-box {
    border: 1.5px solid #ffffff !important;
    padding: 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    background: transparent !important;
    width: 100%;
    max-width: 340px;
  }

  .info-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #1a1a1a;
    margin-bottom: 5px;
  }

  .info-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: 0.5px;
    line-height: 1.4;
  }

  /* ── RIGHT / CENTER ── */
  .col-center {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    gap: 24px;
    position: relative;
    z-index: 2;
    padding-left: 40px;
    margin-top: -30px;
  }

  .bag-wrap {
    width: 320px;
    height: 460px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bag-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    mix-blend-mode: multiply;
  }

  .bag-placeholder-box {
    width: 100%;
    height: 100%;
    border: 1.5px dashed #bbb;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #bbb;
    font-size: 11px;
    font-family: 'Montserrat', sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
    flex-direction: column;
    gap: 10px;
  }

  .badge-wrap {
    width: 190px;
    flex-shrink: 0;
    padding-top: 30px;
    position: relative;
  }

  .badge-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* Desktop connector SVG */
  .connector-svg {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  /* ── TABLET ── */
  @media (max-width: 900px) and (min-width: 601px) {
    .cert-outer { padding: 50px 36px 80px 36px; }
    .cert-grid { grid-template-columns: 280px 1fr; min-height: unset; }
    .cert-tagline { max-width: 100%; }
    .cert-info-box { max-width: 100%; }
    .col-center { padding-left: 16px; margin-top: 0; gap: 16px; }
    .bag-wrap { width: 240px; height: 360px; }
    .badge-wrap { width: 140px; }
    .connector-svg { display: none; }
  }

  /* ── MOBILE ── */
  @media (max-width: 600px) {
    .cert-outer { padding: 28px 18px 50px 18px; }

    .cert-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      min-height: unset;
    }

    .col-left {
      order: 2;
      padding-top: 90px; /* pushed down to clear the connector curve */
      width: 100%;
      gap: 16px;
    }

    .cert-tagline {
      font-size: 8px;
      letter-spacing: 1.5px;
      max-width: 100%;
      line-height: 2;
    }

    .cert-info-box {
      max-width: 100%;
      padding: 20px 16px;
      gap: 16px;
    }

    .info-label { font-size: 9px; }
    .info-val   { font-size: 15px; }

    .col-center {
      order: 1;
      padding-left: 0;
      margin-top: 0;
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
      width: 100%;
      position: relative;
      overflow: visible;
    }

    .bag-wrap {
      width: 55%;
      max-width: 220px;
      height: 280px;
      flex-shrink: 1;
    }

    .badge-wrap {
      width: 40%;
      max-width: 150px;
      padding-top: 16px;
      flex-shrink: 1;
      position: relative;
    }

    .connector-svg {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      pointer-events: none;
      z-index: 1;
      overflow: visible;
    }

    .connector-svg.desktop-only { display: none; }
  }
</style>

<div class="cert-outer">
  <div class="cert-grid" id="certGrid">

    <svg class="connector-svg desktop-only" id="connSvgDesktop" xmlns="http://www.w3.org/2000/svg"></svg>

    <!-- LEFT: tagline + info box -->
    <div class="col-left">
      <p class="cert-tagline">
        This page certifies that your Nalvik product is genuine and part of our Founders Edition
      </p>
      <div class="cert-info-box">
        <div class="info-item">
          <div class="info-label">The Founders Edition:</div>
          <div class="info-val">{{ page.metafields.custom.edition_name | default: 'Crescent Bag' }}</div>
        </div>
        <div class="info-item">
          <div class="info-label">Edition Number:</div>
          <div class="info-val">{{ page.metafields.custom.edition_number | default: 'NAL-CR-01' }}</div>
        </div>
        <div class="info-item">
          <div class="info-label">Authentic Nalvik Product ✓</div>
          <div class="info-val">
            This product has been individually graded and verified by Nalvik
          </div>
        </div>
        <div class="info-item">
          <div class="info-label">Verified by Nalvik:</div>
          <div class="info-val">{{ page.metafields.custom.verified_by | default: 'Nalvik Atelier Colton' }}</div>
        </div>
      </div>
    </div>

    <!-- RIGHT: bag left, badge right -->
    <div class="col-center" id="colCenter">

      <svg class="connector-svg" id="connSvgMobile" xmlns="http://www.w3.org/2000/svg" style="display:none;"></svg>

      <div class="bag-wrap" id="bagEl">
        {% if page.metafields.custom.bag_image.value %}
          <img src="{{ page.metafields.custom.bag_image.value | image_url: width: 600 }}" alt="Nalvik Bag">
        {% else %}
          <div class="bag-placeholder-box">
            <svg width="36" height="36" viewBox="0 0 40 40" fill="none">
              <rect x="8" y="14" width="24" height="20" rx="2" stroke="#bbb" stroke-width="1.5"/>
              <path d="M14 14v-3a6 6 0 0112 0v3" stroke="#bbb" stroke-width="1.5"/>
            </svg>
            Bag Image
          </div>
        {% endif %}
      </div>

      <div class="badge-wrap" id="badgeEl">
        {% if page.metafields.custom.badge_image.value %}
          <img src="{{ page.metafields.custom.badge_image.value | image_url: width: 400 }}" alt="Nalvik Badge">
        {% endif %}
      </div>

    </div>

  </div>
</div>

<script>
  function isMobile() { return window.innerWidth <= 600; }

  /* ── Desktop connector ── */
  function drawDesktop() {
    var grid  = document.getElementById('certGrid');
    var bag   = document.getElementById('bagEl');
    var badge = document.getElementById('badgeEl');
    var svg   = document.getElementById('connSvgDesktop');

    svg.style.display = 'block';
    document.getElementById('connSvgMobile').style.display = 'none';

    var gR = grid.getBoundingClientRect();
    var bR = bag.getBoundingClientRect();
    var dR = badge.getBoundingClientRect();

    var lx = function(v) { return v - gR.left; };
    var ly = function(v) { return v - gR.top; };

    var W = gR.width, H = gR.height + 160;
    svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
    svg.setAttribute('width', W);
    svg.setAttribute('height', H);

    var sx = lx(bR.left + bR.width / 2), sy = ly(bR.bottom);
    var ex = lx(dR.left + dR.width / 2), ey = ly(dR.bottom);

    var lowestBottom = Math.max(sy, ey);
    var drop = lowestBottom + 60;
    var r = 30;

    var linePath =
      'M ' + sx + ' ' + sy +
      ' L ' + sx + ' ' + (drop - r) +
      ' Q ' + sx + ' ' + drop + ' ' + (sx + r) + ' ' + drop +
      ' L ' + (ex - r) + ' ' + drop +
      ' Q ' + ex + ' ' + drop + ' ' + ex + ' ' + (drop - r) +
      ' L ' + ex + ' ' + (ey + 1);

    var ax = ex, ay = ey;
    var hw = 8, th = 11, sw = 2, sh = 14;
    var tri  = ax + ',' + ay + ' ' + (ax - hw) + ',' + (ay + th) + ' ' + (ax + hw) + ',' + (ay + th);
    var stem = 'M ' + (ax - sw) + ' ' + (ay + th) +
               ' L ' + (ax + sw) + ' ' + (ay + th) +
               ' L ' + (ax + sw) + ' ' + (ay + th + sh) +
               ' L ' + (ax - sw) + ' ' + (ay + th + sh) + ' Z';

    svg.innerHTML =
      '<path d="' + linePath + '" fill="none" stroke="#ffffff" stroke-width="2.5"/>' +
      '<polygon points="' + tri + '" fill="#ffffff"/>' +
      '<path d="' + stem + '" fill="#ffffff"/>';
  }

  /* ── Mobile connector ── */
  function drawMobile() {
    var col   = document.getElementById('colCenter');
    var bag   = document.getElementById('bagEl');
    var badge = document.getElementById('badgeEl');
    var svg   = document.getElementById('connSvgMobile');

    document.getElementById('connSvgDesktop').style.display = 'none';
    svg.style.display = 'block';

    var cR = col.getBoundingClientRect();
    var bR = bag.getBoundingClientRect();
    var dR = badge.getBoundingClientRect();

    var lx = function(v) { return v - cR.left; };
    var ly = function(v) { return v - cR.top; };

    var extraH = 100;
    var W = cR.width, H = cR.height + extraH;
    svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
    svg.setAttribute('width', W);
    svg.setAttribute('height', H);

    var sx = lx(bR.left + bR.width / 2);
    var sy = ly(bR.bottom);

    var ex = lx(dR.left + dR.width / 2);
    var ey = ly(dR.bottom);

    var lowestBottom = Math.max(ly(bR.bottom), ly(dR.bottom));
    var drop = lowestBottom + 50;
    var r = 20;

    var linePath =
      'M ' + sx + ' ' + sy +
      ' L ' + sx + ' ' + (drop - r) +
      ' Q ' + sx + ' ' + drop + ' ' + (sx + r) + ' ' + drop +
      ' L ' + (ex - r) + ' ' + drop +
      ' Q ' + ex + ' ' + drop + ' ' + ex + ' ' + (drop - r) +
      ' L ' + ex + ' ' + (ey + 1);

    var ax = ex, ay = ey;
    var hw = 6, th = 9, sw = 1.5, sh = 10;
    var tri  = ax + ',' + ay + ' ' + (ax - hw) + ',' + (ay + th) + ' ' + (ax + hw) + ',' + (ay + th);
    var stem = 'M ' + (ax - sw) + ' ' + (ay + th) +
               ' L ' + (ax + sw) + ' ' + (ay + th) +
               ' L ' + (ax + sw) + ' ' + (ay + th + sh) +
               ' L ' + (ax - sw) + ' ' + (ay + th + sh) + ' Z';

    svg.innerHTML =
      '<path d="' + linePath + '" fill="none" stroke="#ffffff" stroke-width="2"/>' +
      '<polygon points="' + tri + '" fill="#ffffff"/>' +
      '<path d="' + stem + '" fill="#ffffff"/>';
  }

  function drawConnector() {
    if (isMobile()) {
      drawMobile();
    } else if (window.innerWidth > 900) {
      drawDesktop();
    } else {
      document.getElementById('connSvgDesktop').style.display = 'none';
      document.getElementById('connSvgMobile').style.display  = 'none';
    }
  }

  if (document.readyState === 'complete') { drawConnector(); }
  else { window.addEventListener('load', drawConnector); }
  window.addEventListener('resize', drawConnector);
</script>