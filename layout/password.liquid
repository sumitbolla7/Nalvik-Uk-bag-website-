{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  {{ content_for_header }}
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ shop.name }} — Launching Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Montserrat:wght@200;300;400&display=swap" rel="stylesheet">
  <style>

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      height: 100vh;
      overflow: hidden;
      font-family: 'Montserrat', sans-serif;
    }

    /* ── Video / image background ── */
    .bg-media {
      position: fixed;
      inset: 0;
      z-index: 0;
    }
    .bg-media video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .bg-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    /* dark vignette overlay */
    .bg-media::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.18) 0%,
        rgba(0,0,0,0.38) 50%,
        rgba(0,0,0,0.52) 100%
      );
    }

    /* ── Centre overlay ── */
    .overlay {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      text-align: center;
      color: #fff;
      padding: 20px;
    }

    /* logo */
    .logo-img {
      height: 68px;
      width: auto;
      margin-bottom: 10px;
      animation: fadeDown 1s ease both;
    }

    .subtitle {
      font-family: 'Montserrat', sans-serif;
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.38em;
      opacity: 0.78;
      margin-bottom: 48px;
      text-transform: uppercase;
      animation: fadeDown 1s 0.15s ease both;
    }

    /* ── Countdown ── */
    .countdown-wrap {
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: center;
      margin-top: 36px;
      animation: fadeDown 1s 0.3s ease both;
    }
    .countdown-number {
      font-family: 'Montserrat', sans-serif;
      font-size: 34px;
      font-weight: 300;
      line-height: 1;
      letter-spacing: 0.05em;
      color: #fff;
    }
    .countdown-sep {
      font-family: 'Montserrat', sans-serif;
      font-size: 30px;
      font-weight: 300;
      opacity: 0.8;
      line-height: 1;
      margin-top: -4px;
    }

    /* ── Email row ── */
    .cta-label {
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.28em;
      margin-bottom: 14px;
      text-transform: uppercase;
      opacity: 0.88;
      animation: fadeDown 1s 0.45s ease both;
    }

    .email-row {
      position: relative;
      display: flex;
      align-items: center;
      background: rgba(255,255,255,0.92);
      width: 340px;
      animation: fadeDown 1s 0.55s ease both;
    }
    .email-row input {
      width: 100%;
      border: none;
      outline: none;
      padding: 14px 44px;
      font-family: 'Montserrat', sans-serif;
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.18em;
      color: #333;
      background: transparent;
      text-align: center;
      text-transform: uppercase;
    }
    .email-row input::placeholder {
      color: #aaa;
      text-align: center;
    }
    .email-row button {
      position: absolute;
      right: 12px;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 17px;
      color: #555;
      line-height: 1;
      transition: color 0.2s, transform 0.2s;
    }
    .email-row button:hover { color: #111; transform: translateX(2px); }

    /* ── Animations ── */
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Hide ALL Shopify password-page chrome ── */
    #shopify-section-password-header,
    .password-header,
    .password-login,
    .shopify-challenge__container,
    .password-login-form,
    [data-shopify="password-page"],
    main, section, div[role="main"] { display: none !important; }
    #content-for-layout-wrapper { display: none !important; }

    /* ── Success Modal ── */
    #successOverlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.52);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    #successOverlay.active { display: flex; }
    #successModal {
      background: #fff;
      width: 580px;
      max-width: 92vw;
      animation: fadeDown 0.4s ease both;
    }
    #successModal .modal-header {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px 24px;
      border-bottom: 1px solid #e8e8e8;
      position: relative;
    }
    #successModal .modal-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 24px;
      letter-spacing: 0.22em;
      font-weight: 400;
      color: #111;
    }
    #successModal .modal-close {
      position: absolute;
      right: 20px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
      color: #888;
      cursor: pointer;
      background: none;
      border: none;
      transition: color 0.2s;
    }
    #successModal .modal-close:hover { color: #111; }
    #successModal .modal-body {
      padding: 72px 40px;
      text-align: center;
    }
    #successModal .modal-body p {
      font-family: 'Montserrat', sans-serif;
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.2em;
      color: #333;
      text-transform: uppercase;
      line-height: 2;
    }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      .countdown-number { font-size: 38px; }
      .countdown-wrap { gap: 18px; }
      .email-row { width: 290px; }
      .logo-img { height: 52px; }
    }
  </style>
</head>
<body>

  <!-- Background: video first, image fallback -->
  <div class="bg-media">
    <video autoplay muted loop playsinline poster="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/BAG_IMG_LAUNCHING_SOON_1.png?v=1776098976">
      <source src="https://cdn.shopify.com/videos/c/o/v/f387b48932a44e98bb6e0d4a9e094a74.mp4" type="video/mp4" />
      <!-- fallback for browsers that don't support video -->
      <img src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/BAG_IMG_LAUNCHING_SOON_1.png?v=1776098976" alt="NALVIK" />
    </video>
  </div>

  <div class="overlay">

    <img
      class="logo-img"
      src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/logo_for_launching_soon_page.png?v=1777558328"
      alt="NALVIK"
    />
    <div class="subtitle">Launching Soon</div>

    <div class="cta-label" id="ctaLabel">Enable Early Access</div>

    {% form 'customer', id: 'email-signup' %}
      <input type="hidden" name="contact[tags]" value="newsletter,email subscriber" />
      <input type="hidden" name="contact[accepts_marketing]" value="1" />
      <div class="email-row" id="emailBox">
        <input
          type="email"
          name="contact[email]"
          placeholder="EMAIL"
          required
          autocomplete="off"
        />
        <button type="submit">→</button>
      </div>
    {% endform %}

    <!-- Countdown timer -->
    <div class="countdown-wrap" id="countdown">
      <span class="countdown-number" id="cd-days">25</span>
      <span class="countdown-sep">;</span>
      <span class="countdown-number" id="cd-hours">00</span>
      <span class="countdown-sep">;</span>
      <span class="countdown-number" id="cd-mins">00</span>
      <span class="countdown-sep">;</span>
      <span class="countdown-number" id="cd-secs">00</span>
    </div>

  </div>

  <!-- Success Modal -->
  <div id="successOverlay">
    <div id="successModal">
      <div class="modal-header">
        <span class="modal-logo">NALVIK</span>
        <button class="modal-close" onclick="document.getElementById('successOverlay').classList.remove('active')">✕</button>
      </div>
      <div class="modal-body">
        <p>You'll be the first one to know<br>when NALVIK launches.</p>
      </div>
    </div>
  </div>

  <!-- Required by Shopify — hidden via CSS -->
  <div id="content-for-layout-wrapper">{{ content_for_layout }}</div>

  <script>
    /* ─────────────────────────────────────────────
       COUNTDOWN TIMER
       Target = 25 days from June 17, 2026.
       Fixed deadline is used so the countdown shows
       exactly the same time for all users.
    ───────────────────────────────────────────── */
    (function () {
      var deadline = new Date('2026-07-12T00:00:00+05:30').getTime();

      function pad(n) { return n < 10 ? '0' + n : '' + n; }

      function tick() {
        var diff = deadline - Date.now();
        if (diff <= 0) {
          document.getElementById('cd-days').textContent  = '00';
          document.getElementById('cd-hours').textContent = '00';
          document.getElementById('cd-mins').textContent  = '00';
          document.getElementById('cd-secs').textContent  = '00';
          return;
        }
        var days  = Math.floor(diff / 86400000);
        var hours = Math.floor((diff % 86400000) / 3600000);
        var mins  = Math.floor((diff % 3600000)  / 60000);
        var secs  = Math.floor((diff % 60000)    / 1000);

        document.getElementById('cd-days').textContent  = pad(days);
        document.getElementById('cd-hours').textContent = pad(hours);
        document.getElementById('cd-mins').textContent  = pad(mins);
        document.getElementById('cd-secs').textContent  = pad(secs);
      }

      tick();
      setInterval(tick, 1000);
    })();

    /* ─────────────────────────────────────────────
       SUCCESS STATE after Shopify form redirect
    ───────────────────────────────────────────── */
    window.addEventListener('load', function () {
      if (window.location.href.indexOf('customer_posted=true') > -1) {
        document.getElementById('emailBox').style.display  = 'none';
        document.getElementById('ctaLabel').style.display  = 'none';
        document.getElementById('successOverlay').classList.add('active');
      }
    });
  </script>

</body>
</html>
