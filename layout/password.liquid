{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  {{ content_for_header }}
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ shop.name }} — Launching Soon</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000;
      font-family: 'Montserrat', sans-serif;
    }

    #nv-wrap {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }

    /* Full-bleed video */
    #nv-video {
      position: absolute;
      inset: 0;
      z-index: 1;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      opacity: 0;
      transition: opacity 1.6s ease;
    }
    #nv-video.loaded { opacity: 1; }

    /* Vignette */
    #nv-vignette {
      position: absolute;
      inset: 0;
      z-index: 2;
      background: radial-gradient(ellipse at center, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.42) 100%);
    }

    /* Content — vertically centered */
    #nv-content {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem 1.5rem;
      gap: 0;
    }

    /* ── NALVIK Logo ── */
    .nv-logo {
      height: clamp(52px, 6vw, 68px);
      width: auto;
      display: block;
      margin: 0 auto clamp(1.2rem, 3.5vh, 2rem) auto; /* Centered with bottom spacing */
    }

    /* ── ENABLE EARLY ACCESS ── */
    .nv-label {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(0.52rem, 1vw, 0.62rem);
      font-weight: 400;
      letter-spacing: 0.38em;
      color: rgba(255,255,255,0.88);
      text-transform: uppercase;
      margin-bottom: 0.85rem;
    }

    /* ── Email form ── */
    .nv-form-row {
      display: flex;
      align-items: center;
      width: clamp(240px, 38vw, 340px);
      height: 44px;
      margin-bottom: clamp(1.8rem, 4vh, 3rem);
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .nv-input {
      flex: 1;
      height: 100%;
      padding: 0 14px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      color: #fff;
      background: transparent;
      border: none;
      outline: none;
      text-align: center;
      text-transform: uppercase;
      -webkit-appearance: none;
      appearance: none;
    }
    .nv-input::placeholder { color: rgba(255,255,255,0.4); letter-spacing: 0.2em; }
    .nv-input:focus { background: transparent; }

    .nv-btn {
      width: 44px;
      height: 100%;
      background: transparent;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s;
      opacity: 0.7;
    }
    .nv-btn:hover { opacity: 1; }
    .nv-btn svg {
      width: 13px; height: 13px;
      stroke: #fff; fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .nv-err {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.15em;
      color: #ff7070;
      text-transform: uppercase;
      margin-top: -1rem;
      margin-bottom: 0.8rem;
      display: none;
    }

    /* ── Timer — Plain text style in Inter font ── */
    .nv-timer {
      margin-top: 0.5rem;
    }

    .nv-timer__digits {
      font-family: 'Inter', sans-serif;
      font-size: clamp(1.4rem, 3.5vw, 2.2rem); /* Plain text size */
      font-weight: 400; /* Plain text font weight */
      letter-spacing: 0.08em;
      color: #ffffff; /* Plain white color */
      font-variant-numeric: tabular-nums;
      line-height: 1.2;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Modal ── */
    #nv-modal {
      position: fixed; inset: 0; z-index: 200;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,0.6);
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s ease;
      padding: 1.5rem;
    }
    #nv-modal.open { opacity: 1; pointer-events: auto; }

    .nv-modal-box {
      background: #fff; width: 100%; max-width: 330px;
      padding: 2.6rem 2rem 2.2rem; position: relative;
      transform: translateY(14px); transition: transform 0.35s ease;
    }
    #nv-modal.open .nv-modal-box { transform: translateY(0); }

    .nv-modal-brand {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem; letter-spacing: 0.45em; color: #111;
      text-transform: uppercase; text-align: center;
      padding-bottom: 1.1rem; border-bottom: 1px solid #e8e8e8; margin-bottom: 1.5rem;
    }
    .nv-modal-msg {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.6rem; font-weight: 400; letter-spacing: 0.2em;
      color: #111; text-transform: uppercase; text-align: center; line-height: 2;
    }
    .nv-modal-x {
      position: absolute; top: 12px; right: 12px;
      background: none; border: none; cursor: pointer;
      padding: 5px; opacity: 0.4; transition: opacity 0.2s; line-height: 1;
    }
    .nv-modal-x:hover { opacity: 1; }
    .nv-modal-x svg { width: 12px; height: 12px; stroke: #111; fill: none; stroke-width: 2; stroke-linecap: round; }

    /* Hide standard shopify password headers/footers */
    #shopify-section-password-header,
    .password-header,
    .password-login,
    .shopify-challenge__container,
    .password-login-form,
    [data-shopify="password-page"],
    main, section, div[role="main"] { display: none !important; }
    #content-for-layout-wrapper { display: none !important; }

    @media (max-width: 480px) {
      .nv-form-row { width: 100%; max-width: 300px; }
    }
  </style>
</head>
<body>

  <div id="nv-wrap">
    <video id="nv-video" autoplay muted loop playsinline preload="auto">
      <source src="https://cdn.shopify.com/videos/c/o/v/f387b48932a44e98bb6e0d4a9e094a74.mp4" type="video/mp4">
    </video>
    <div id="nv-vignette" aria-hidden="true"></div>

    <div id="nv-content">

      <!-- NALVIK Logo -->
      <img
        class="nv-logo"
        src="https://cdn.shopify.com/s/files/1/0812/9626/1360/files/logo_for_launching_soon_page_42e2f836-6490-4853-a8ba-e6262d53dbcc.png?v=1781087057"
        alt="NALVIK"
      />

      <!-- ENABLE EARLY ACCESS -->
      <p class="nv-label">Enable Early Access</p>

      <!-- Email form -->
      {% form 'customer', id: 'email-signup', class: 'nv-form' %}
        <input type="hidden" name="contact[tags]" value="early-access, newsletter" />
        <input type="hidden" name="contact[accepts_marketing]" value="1" />
        <div class="nv-form-row">
          <input
            class="nv-input"
            type="email"
            name="contact[email]"
            id="nv-email"
            placeholder="EMAIL"
            required
            autocomplete="email"
          />
          <button class="nv-btn" id="nv-btn" type="submit" aria-label="Submit">
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      {% endform %}

      <!-- Timer -->
      <div class="nv-timer">
        <div class="nv-timer__digits" id="nv-clock">00:00</div>
      </div>

    </div>
  </div>

  <!-- Success Modal -->
  <div id="nv-modal" role="dialog" aria-modal="true">
    <div class="nv-modal-box">
      <button class="nv-modal-x" id="nv-close" aria-label="Close" onclick="document.getElementById('nv-modal').classList.remove('open')">
        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <p class="nv-modal-brand">NALVIK</p>
      <p class="nv-modal-msg">You'll be the first one<br>to know when NALVIK<br>launches</p>
    </div>
  </div>

  <!-- Required by Shopify — hidden via CSS -->
  <div id="content-for-layout-wrapper">{{ content_for_layout }}</div>

  <script>
  (function(){
    /* ── Video ── */
    var v = document.getElementById('nv-video');
    if(v){
      var go = function(){ v.classList.add('loaded'); };
      v.addEventListener('canplay', go);
      v.addEventListener('loadeddata', go);
      if(v.readyState >= 3) go();
      v.load(); v.play().catch(function(){});
    }

    /* ── Countdown ── */
    // Target: July 8, 2026, 18:00:00 (25 days from June 13)
    var ts = new Date("2026-07-08T18:00:00+05:30").getTime();

    function pad(n){ return ('0' + n).slice(-2); }

    function tick(){
      var diff = Math.max(0, ts - Date.now());
      var s    = Math.floor(diff / 1000);
      var days = Math.floor(s / 86400);
      var hh   = Math.floor((s % 86400) / 3600);
      var mm   = Math.floor((s % 3600) / 60);
      var ss   = s % 60;
      var el   = document.getElementById('nv-clock');
      if(el) {
        if (days > 0) {
          el.textContent = pad(days) + ':' + pad(hh) + ':' + pad(mm) + ':' + pad(ss);
        } else if (hh > 0) {
          el.textContent = pad(hh) + ':' + pad(mm) + ':' + pad(ss);
        } else {
          el.textContent = pad(mm) + ':' + pad(ss);
        }
      }
    }
    tick();
    setInterval(tick, 1000);

    /* ── Success State ── */
    window.addEventListener('load', function () {
      if (window.location.search.indexOf('customer_posted=true') > -1) {
        var modal = document.getElementById('nv-modal');
        if (modal) {
          modal.classList.add('open');
        }
      }
    });

    /* ── Modal Escape Close ── */
    document.addEventListener('keydown', function(e){
      if(e.key==='Escape') {
        var modal = document.getElementById('nv-modal');
        if (modal) modal.classList.remove('open');
      }
    });
  })();
  </script>

</body>
</html>
